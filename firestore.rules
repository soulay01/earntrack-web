rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuth() {
      return request.auth != null;
    }

    function userCompanyId() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return (userDoc != null && userDoc.data != null && userDoc.data.companyId != null) ? userDoc.data.companyId : request.auth.uid;
    }

    function belongsToMyCompany() {
      return resource.data.companyId == userCompanyId()
          || (resource.data.createdBy != null && resource.data.createdBy == request.auth.uid);
    }

    function belongsToMyCompanyRequest() {
      return request.resource.data.companyId == userCompanyId();
    }

    // companyId darf bei create frei gesetzt werden (siehe belongsToMyCompanyRequest), aber
    // bei update niemals wechseln – sonst könnte ein User ein eigenes Dokument nachträglich
    // einer fremden Firma "unterschieben" (Cross-Tenant-Dateninjektion). isAdmin() darf es,
    // analog zu den anderen Admin-Bypasses in dieser Datei.
    function companyIdUnchanged() {
      return request.resource.data.companyId == resource.data.companyId || isAdmin();
    }

    function isOwner() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data != null && userDoc.data.role == 'owner';
    }

    function assignmentInMyCompany(assignmentId) {
      let assignmentDoc = get(/databases/$(database)/documents/assignments/$(assignmentId));
      return (assignmentDoc != null && assignmentDoc.data != null) && (
        assignmentDoc.data.companyId == userCompanyId() ||
        (assignmentDoc.data.createdBy != null && assignmentDoc.data.createdBy == request.auth.uid)
      );
    }

    function noteInMyCompany(noteId) {
      let note = get(/databases/$(database)/documents/project_notes/$(noteId));
      return note != null && note.data != null && note.data.assignmentId != null && assignmentInMyCompany(note.data.assignmentId);
    }

    function isAdmin() {
      let adminEmails = get(/databases/$(database)/documents/app_config/admin_emails);
      return adminEmails != null && adminEmails.data != null && adminEmails.data.emails != null
        && request.auth.token.email in adminEmails.data.emails;
    }

    // Plan-Stand der Firma – Default 'trial' spiegelt getFeatureFlag() in src/lib/plans.ts.
    function companyPlan() {
      let companyDoc = get(/databases/$(database)/documents/companies/$(userCompanyId()));
      return (companyDoc != null && companyDoc.data != null && companyDoc.data.subscriptionPlan != null)
        ? companyDoc.data.subscriptionPlan : 'trial';
    }

    // Mahnwesen & wiederkehrende Rechnungen sind aktuell identisch gegated (nur 'solo' ausgeschlossen,
    // siehe PLAN_FEATURES in src/lib/plans.ts). Ein Feature-Parameter würde hier nichts bringen, da
    // Firestore-Rules keine Maps als Funktionsargumente für dynamische Lookups unterstützen –
    // bei künftig abweichender Gating-Logik einfach eine zweite Funktion ergänzen.
    function planAllowsSoloRestrictedFeature() {
      return companyPlan() != 'solo';
    }

    // Erkennt den einen sicherheitsrelevanten Statuswechsel auf Assignments: Rechnung in Mahnung setzen.
    function isDunningStatusChange() {
      return request.resource.data.invoiceStatus in ['mahnung_1', 'mahnung_2']
        && (!('invoiceStatus' in resource.data) || request.resource.data.invoiceStatus != resource.data.invoiceStatus);
    }

    // Prüft, ob der User schreibend auf seine Daten zugreifen darf.
    // past_due: Zahlung überfällig, aber Nutzung noch erlaubt (Stripe-Grace-Periode)
    // paused:   RevenueCat-Pause, Nutzung noch erlaubt
    // cancelled: 7-Tage-Gnadenfrist für Datenexport und Fertigstellung
    // expired:   Kein Schreibzugriff mehr (Daten gelöscht)
    function canWriteData() {
      let companyDoc = get(/databases/$(database)/documents/companies/$(userCompanyId()));
      return companyDoc != null && companyDoc.data != null && (
        companyDoc.data.subscriptionStatus == 'active' ||
        companyDoc.data.subscriptionStatus == 'trial' ||
        companyDoc.data.subscriptionStatus == 'trialing' ||
        companyDoc.data.subscriptionStatus == 'past_due' ||
        companyDoc.data.subscriptionStatus == 'paused' ||
        companyDoc.data.subscriptionStatus == 'cancelled'
        // 'expired' bewusst NICHT erlaubt: Kein Schreibzugriff mehr nach Ablauf
      ) || isAdmin();
    }

    // ─── Users ───
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || (resource != null && resource.data.companyId == request.auth.uid) || isAdmin());
      // Self-create nur innerhalb der EIGENEN company (companyId == uid oder nicht gesetzt).
      // Verhindert, dass ein User sich per companyId=<fremde-uid> in eine fremde Firma einschleust.
      allow create: if isAuth() && (
        (request.auth.uid == uid
          && (!('companyId' in request.resource.data) || request.resource.data.companyId == uid))
        || (isOwner() && request.resource.data.companyId == userCompanyId() && request.resource.data.role == 'employee')
      );
      // companyId und role sind für Clients unveränderlich – nur serverseitig (Admin SDK) / über den
      // Owner-Zweig bei Anlage setzbar. Self-Update darf beliebige andere Felder ändern, aber nie eskalieren.
      // Fremde Profile darf nur der Owner ändern, nicht jeder beliebige Kollege (sonst horizontale
      // Rechteausweitung: ein normaler Mitarbeiter könnte sonst z. B. das Owner-Profil überschreiben).
      allow update: if isAuth() && (
        request.resource.data.role == resource.data.role
        && request.resource.data.companyId == resource.data.companyId
        && (request.auth.uid == uid || (isOwner() && resource.data.companyId == userCompanyId()))
      );
      allow delete: if isAuth() && isAdmin();
    }

    // Felder, die nur serverseitig (Admin SDK) geschrieben werden dürfen.
    // Clients dürfen diese Felder niemals direkt setzen.
    function isSubscriptionField(keys) {
      return keys.hasAny([
        'subscriptionStatus', 'subscriptionPlan', 'trialEndsAt',
        'nextBillingDate', 'subscriptionStartDate', 'excessCleanupAt',
        'dataCleanupAt', 'iapRestoreBlocked'
      ]);
    }

    // ─── Companies ───
    match /companies/{companyId} {
      allow read: if isAuth() && (request.auth.uid == companyId || userCompanyId() == companyId || isAdmin());
      allow create: if isAuth() && request.auth.uid == companyId
        && !isSubscriptionField(request.resource.data.keys());
      allow update: if isAuth() && request.auth.uid == companyId && canWriteData()
        && !isSubscriptionField(request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAuth() && request.auth.uid == companyId && isAdmin();

      // Bewusst einzeln statt {document=**}: 'recurring' braucht eine Plan-Prüfung
      // (wiederkehrende Rechnungen sind im Solo-Plan nicht enthalten), alle anderen
      // Subcollections nicht. Neue Subcollection hinzugefügt? Hier einen Match ergänzen.
      match /estimateTemplates/{id} {
        allow read, write: if isAuth() && request.auth.uid == companyId;
      }
      match /settings/{id} {
        allow read, write: if isAuth() && request.auth.uid == companyId;
      }
      match /private/{id} {
        allow read, write: if isAuth() && request.auth.uid == companyId;
      }
      match /recurring/{id} {
        allow read: if isAuth() && request.auth.uid == companyId;
        allow write: if isAuth() && request.auth.uid == companyId && (planAllowsSoloRestrictedFeature() || isAdmin());
      }
    }

    // ─── Assignments ───
    match /assignments/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin());
      allow create: if isAuth() && request.resource.data.companyId == userCompanyId() && canWriteData();
      allow update: if isAuth() && (belongsToMyCompany() || isAdmin()) && canWriteData() && companyIdUnchanged()
        && (!isDunningStatusChange() || planAllowsSoloRestrictedFeature() || isAdmin());
      allow delete: if isAuth() && (belongsToMyCompany() || isAdmin()) && canWriteData();
    }

    // ─── Employees ───
    match /employees/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin());
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      // Mitarbeiter dürfen ihr eigenes Profilbild selbst setzen (per E-Mail-Match auf
      // den eigenen Auth-Account) – aber NUR dieses Feld, kein Zugriff auf Lohn o.ä.
      allow update: if isAuth() && companyIdUnchanged() && (
        (belongsToMyCompany() && canWriteData()) ||
        resource.data.uid == request.auth.uid ||
        (
          resource.data.email != null &&
          request.auth.token.email != null &&
          resource.data.email.lower() == request.auth.token.email.lower() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrl', 'updatedAt'])
        )
      );
      allow delete: if isAuth() && (belongsToMyCompany() || isAdmin()) && canWriteData();
    }

    // ─── Customers ───
    match /customers/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin());
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if isAuth() && belongsToMyCompany() && canWriteData() && companyIdUnchanged();
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Clock entries ───
    match /clock_entries/{doc} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.assignmentId != null && assignmentInMyCompany(resource.data.assignmentId)) ||
        isAdmin()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Project notes ───
    match /project_notes/{doc} {
      allow read: if isAuth() && (resource.data.assignmentId != null && (assignmentInMyCompany(resource.data.assignmentId) || isAdmin()));
      allow create: if isAuth() && request.resource.data.assignmentId != null && assignmentInMyCompany(request.resource.data.assignmentId) && canWriteData();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && ((resource.data.userId == request.auth.uid) || (belongsToMyCompany() && canWriteData()));
    }

    // ─── Project note replies ───
    match /project_note_replies/{doc} {
      allow read: if isAuth() && (
        (resource.data.assignmentId != null && (assignmentInMyCompany(resource.data.assignmentId) || isAdmin())) ||
        (resource.data.noteId != null && (noteInMyCompany(resource.data.noteId) || isAdmin()))
      );
      allow create: if isAuth() && request.resource.data.noteId != null && noteInMyCompany(request.resource.data.noteId) && canWriteData();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─── Project photos ───
    match /project_photos/{doc} {
      allow read: if isAuth() && resource.data.assignmentId != null && (assignmentInMyCompany(resource.data.assignmentId) || isAdmin());
      allow create: if isAuth() && request.resource.data.assignmentId != null && assignmentInMyCompany(request.resource.data.assignmentId) && canWriteData();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─── Project members ───
    match /project_members/{assignmentId} {
      allow read: if isAuth() && (assignmentInMyCompany(assignmentId) || (resource != null && resource.data[request.auth.uid] != null) || isAdmin());
      // Self-Join lief früher hierüber (request.resource.data[uid] != null), erlaubte damit aber
      // jedem beliebigen authentifizierten User, die komplette Mitgliederliste jedes fremden
      // Projekts zu überschreiben. Der einzige echte Self-Join-Pfad ist die Cloud Function
      // redeemInviteCode (Admin-SDK, transaktional, prüft den Invite-Code) – kein Client-Direktzugriff nötig.
      allow write: if isAuth() && (
        (assignmentInMyCompany(assignmentId) && canWriteData()) ||
        isAdmin()
      );
    }

    // ─── Project invites ───
    match /project_invites/{doc} {
      allow read: if isAuth() && (
        resource == null ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.recipientEmail == request.auth.token.email ||
        assignmentInMyCompany(resource.data.assignmentId)
      );
      allow create: if isAuth() && request.resource.data.assignmentId != null && assignmentInMyCompany(request.resource.data.assignmentId) && canWriteData();
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        (!resource.data.usedBy && request.resource.data.usedBy == request.auth.uid)
      );
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    // ─── Notifications ───
    match /notifications/{doc} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isAuth() && (request.resource.data.recipientId == request.auth.uid || request.resource.data.assignmentId != null && assignmentInMyCompany(request.resource.data.assignmentId));
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }

    // ─── Estimates ───
    match /estimates/{doc} {
      allow read: if isAuth() && belongsToMyCompany();
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if isAuth() && belongsToMyCompany() && canWriteData() && companyIdUnchanged();
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Invoices ───
    match /invoices/{doc} {
      allow read: if isAuth() && belongsToMyCompany();
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if isAuth() && belongsToMyCompany() && canWriteData() && companyIdUnchanged();
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Suppliers ───
    match /suppliers/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin());
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if isAuth() && belongsToMyCompany() && canWriteData() && companyIdUnchanged();
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Inventory (Lager) ───
    match /inventory_items/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin());
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if isAuth() && belongsToMyCompany() && canWriteData() && companyIdUnchanged();
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }
    match /inventory_movements/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin());
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if false;
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Expenses ───
    match /expenses/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin());
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if isAuth() && belongsToMyCompany() && canWriteData() && companyIdUnchanged();
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Articles ───
    match /articles/{doc} {
      allow read: if isAuth() && belongsToMyCompany();
      allow create: if isAuth() && belongsToMyCompanyRequest() && canWriteData();
      allow update: if isAuth() && belongsToMyCompany() && canWriteData() && companyIdUnchanged();
      allow delete: if isAuth() && belongsToMyCompany() && canWriteData();
    }

    // ─── Payment requests ───
    match /payment_requests/{doc} {
      allow read: if isAuth() && (belongsToMyCompany() || isAdmin() || resource.data.userEmail == request.auth.token.email);
      allow create: if isAuth() && belongsToMyCompanyRequest();
      allow update: if isAuth() && (belongsToMyCompany() || isAdmin()) && companyIdUnchanged();
      allow delete: if isAuth() && (belongsToMyCompany() || isAdmin());
    }

    // ─── Usage log ───
    match /usage_log/{doc} {
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // ─── Demo signups ───
    match /demo_signups/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // ─── Activity events (granulares Event-Log für Live-Feed & User-Historie) ───
    match /activity_events/{doc} {
      allow read: if isAuth() && isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Manual pro users ───
    match /manual_pro_users/{doc} {
      allow read: if isAuth() && (resource.data.email == request.auth.token.email || isAdmin());
      allow write: if isAdmin();
    }

    // ─── Page views (server-side only via admin SDK) ───
    match /page_views/{doc} {
      allow read, write: if false;
    }

    // ─── App config ───
    // Nur authentifizierte User dürfen lesen (schützt Admin-Email-Liste vor Enumeration).
    match /app_config/{doc} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ─── Feedback ───
    match /feedback/{doc} {
      allow read: if isAuth() && isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'new';
      allow update: if isAuth() && isAdmin();
      allow delete: if false;
    }

    // ─── Deny everything else ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
