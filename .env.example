# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe (Next.js)
STRIPE_SECRET_KEY=
STRIPE_TEST_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PRICE_SOLO=
NEXT_PUBLIC_STRIPE_PRICE_TEAM=
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=
NEXT_PUBLIC_STRIPE_TEST_PRICE_SOLO=
NEXT_PUBLIC_STRIPE_TEST_PRICE_TEAM=
NEXT_PUBLIC_STRIPE_TEST_PRICE_BUSINESS=
# Server-only: steuert ob Test- oder Live-Stripe-Key genutzt wird (KEIN NEXT_PUBLIC_!)
STRIPE_TEST_MODE=false

# Stripe (Cloud Functions)
STRIPE_TEST_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=
STRIPE_TEST_WEBHOOK_SECRET_KEY=

# Admin Cookie-Secret (für Analytics-Middleware – per `openssl rand -hex 32` generieren)
ADMIN_COOKIE_SECRET=

# Pageview Analytics Salt (für IP-Hashing – per `openssl rand -hex 32` generieren, DSGVO-Pflicht)
PAGEVIEW_SALT=

# Admin (server-side only — never uses NEXT_PUBLIC_ prefix)
ADMIN_EMAILS=

# EmailJS
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Firebase Admin
GOOGLE_APPLICATION_CREDENTIALS=

# Site URLs
NEXT_PUBLIC_SITE_URL=https://earntrack.de
NEXT_PUBLIC_LOGIN_URL=https://app.earntrack.de/login
ALLOWED_CORS_ORIGINS=https://earntrack.de,https://app.earntrack.de

# Site URL (used by Cloud Functions)
SITE_URL=https://earntrack.de
ADMIN_EMAIL=

# Sentry (EU-Hosting)
NEXT_PUBLIC_SENTRY_DSN=
